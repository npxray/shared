{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!dist",
      "!**/dist",
      "!coverage",
      "!bun.lock",
      "!packages/contracts/src/generated.ts",
      "!packages/contracts/src/signal-catalog.generated.ts",
      "!packages/contracts/src/signal-catalog.json",
      "!packages/contracts/src/report.schema.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noConsole": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
